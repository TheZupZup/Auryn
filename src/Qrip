#!/usr/bin/env bash
# Qrip
# Simple Zenity GUI wrapper for streamrip ("rip")

# -------------------------------------------------------

# Goals:
# - Provide a simple GUI on Linux Mint (and most distros) to download from Qobuz using streamrip.
# - Ask user for: Qobuz URL + Destination folder.
# - Run `rip url <URL>` and show a progress dialog.
# - Keep logs for debugging.
# - Avoid the common "Skipping track... marked as downloaded" issue by using an isolated config/db per run.
#
# IMPORTANT:
# - This script does NOT contain Qobuz keys or DRM circumvention.
# - It is only a UI wrapper around streamrip/streamrip (rip).
#
# Dependencies:
# - bash
# - zenity
# - streamrip installed as `rip` (recommended via `pipx install streamrip`)
#
# Suggested install paths:
# - ~/.local/bin/Qrip
# - ~/.local/share/applications/Qrip.desktop
# Graphical wrapper for streamrip with auto-organization for NAS
# Supports: Qobuz, Tidal, Deezer, SoundCloud

set -euo pipefail

# --- Settings & Paths ---
APP_NAME="Qrip"
APP_TITLE="Qrip"
APP_VERSION="2.0.0"
STATE_DIR="${HOME}/.local/state/qrip"
LOG_DIR="${STATE_DIR}/logs"
CFG_FILE="${HOME}/.config/streamrip/config.toml"
mkdir -p "$LOG_DIR"

# --- Requirements ---
need() {
    if ! command -v "$1" >/dev/null 2>&1; then
        zenity --error --title="$APP_NAME" --text="Required tool '$1' is missing.\n\nPlease install it to continue."
        exit 1
    fi
}
need rip
need zenity
need metaflac

# --- UI: Link & Destination ---
# Extract current folder from config as default
DEFAULT_DEST=$(grep -E '^\s*folder\s*=' "$CFG_FILE" | head -n1 | cut -d'"' -f2 || echo "$HOME/Music")

FORM=$(zenity --forms --title="$APP_NAME $APP_VERSION" \
    --text="Fill in the details to start downloading" \
    --add-entry="Paste URL (Qobuz/Tidal/Deezer/SoundCloud)" \
    --add-entry="Library Folder (NAS or Local)" \
    --separator="|" \
    --width=650)

[ -z "$FORM" ] && exit 0

URL=$(echo "$FORM" | cut -d'|' -f1 | xargs)
BASE_DEST=$(echo "$FORM" | cut -d'|' -f2 | xargs)
[ -z "$BASE_DEST" ] && BASE_DEST="$DEFAULT_DEST"

# --- Quality Selection ---
# Matches your HTML portal options
Q_CHOICE=$(zenity --list --title="$APP_NAME - Quality" \
    --text="Select Audio Quality" --radiolist \
    --column="Select" --column="ID" --column="Quality" \
    FALSE "0" "MP3 (128 kbps)" \
    FALSE "1" "MP3 (320 kbps)" \
    FALSE "2" "FLAC (16-bit/44.1kHz)" \
    TRUE  "3" "Hi-Res FLAC (24-bit/96kHz+)" \
    FALSE "4" "Max Available (MQA/Original)" \
    --width=400 --height=300)

[ -z "$Q_CHOICE" ] && exit 0

# --- Process: Download & Organize ---
STAGING_DIR="/tmp/qrip_staging_$(date +%s)"
mkdir -p "$STAGING_DIR"
LOG_FILE="${LOG_DIR}/qrip_$(date +%Y%m%d_%H%M%S).log"

(
    echo "# Preparing isolated environment..."
    # Backup and temp modify config
    sed -i.bak "s|folder = .*|folder = \"$STAGING_DIR\"|" "$CFG_FILE"
    sed -i "s|^quality = .*|quality = $Q_CHOICE|" "$CFG_FILE"

    echo "# Downloading tracks from service..."
    rip url "$URL" 2>&1 | tee "$LOG_FILE"

    echo "# Moving and sorting files: Artist > Album > Quality..."
    # Find all flac files and organize them
    find "$STAGING_DIR" -type f -name "*.flac" | while read -r file; do
        ARTIST=$(metaflac --show-tag=ARTIST "$file" | cut -d= -f2 | sed 's/\//-/g' || echo "Unknown Artist")
        ALBUM=$(metaflac --show-tag=ALBUM "$file" | cut -d= -f2 | sed 's/\//-/g' || echo "Unknown Album")
        BPS=$(metaflac --show-bps "$file")
        SR=$(metaflac --show-sample-rate "$file")
        
        # Folder naming: e.g., "FLAC 24bit-48kHz"
        DIR_NAME="FLAC ${BPS}bit-$((SR/1000))kHz"
        FINAL_PATH="$BASE_DEST/$ARTIST/$ALBUM/$DIR_NAME"
        
        mkdir -p "$FINAL_PATH"
        mv "$file" "$FINAL_PATH/"
    done

    # Cleanup
    mv "$CFG_FILE.bak" "$CFG_FILE"
    rm -rf "$STAGING_DIR"
    
    echo "100"
    echo "# Download Successful!"
) | zenity --progress --title="$APP_NAME" --text="Starting process..." --pulsate --auto-close

# --- Finish ---
if zenity --question --title="Complete" --text="Music organized in: $BASE_DEST\nOpen folder now?"; then
    xdg-open "$BASE_DEST"
fi
