<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0d0d0d; --surf:#141414; --surf2:#1c1c1c;
  --bdr:#2a2a2a; --bdr2:#383838;
  --or:#FF6B35; --red:#C0392B;
  --odim:rgba(255,107,53,.14);
  --tx:#e8e8e8; --dim:#888; --muted:#444;
  --gr:#87a556;
  --mono:'JetBrains Mono',monospace;
  --sans:'DM Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

body{
  background:var(--bg);
  font-family:var(--sans);
  font-size:13px;
  color:var(--tx);
  min-height:100vh;
}

/* grid bg — pointer-events OFF so it never blocks clicks */
.bg-grid{
  position:fixed;inset:0;
  background-image:
    linear-gradient(var(--bdr) 1px,transparent 1px),
    linear-gradient(90deg,var(--bdr) 1px,transparent 1px);
  background-size:40px 40px;
  opacity:.14;
  pointer-events:none;
  z-index:0;
}

/* everything above grid */
.topbar,.tab,.toast-wrap{position:relative;z-index:10;}

/* ── TOPBAR ── */
.topbar{
  position:sticky;top:0;z-index:100;
  background:rgba(13,13,13,.96);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--bdr);
  height:52px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 22px;
}
.logo{font-family:var(--mono);font-size:.95rem;font-weight:700;display:flex;align-items:center;gap:9px;color:var(--tx);}
.logo span{color:var(--or);}
.pills{display:flex;gap:5px;}
.pill{font-family:var(--mono);font-size:.53rem;letter-spacing:.12em;padding:2px 9px;border-radius:20px;border:1px solid var(--bdr2);color:var(--dim);}
.nav{display:flex;gap:4px;}
.nbtn{font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;padding:5px 13px;border-radius:4px;border:1px solid var(--bdr);background:transparent;color:var(--dim);cursor:pointer;transition:all .15s;}
.nbtn:hover{border-color:var(--or);color:var(--or);}
.nbtn.on{background:var(--odim);border-color:var(--or);color:var(--or);}
@media(max-width:580px){.pills{display:none;}}

/* ── TABS ── */
.tab{display:none;}.tab.on{display:block;}

/* ── PAGE CONTENT ── */
.page{max-width:980px;margin:0 auto;padding:26px 18px 80px;}
.gpage{max-width:840px;margin:0 auto;padding:26px 18px 80px;}

/* ── TOAST ── */
.toast-wrap{position:fixed;top:58px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:6px;pointer-events:none;}
.toast{font-family:var(--mono);font-size:11px;padding:9px 14px;border-radius:6px;border-left:3px solid var(--or);background:var(--surf);color:var(--dim);box-shadow:0 4px 20px rgba(0,0,0,.5);transform:translateX(120%);transition:transform .28s cubic-bezier(.16,1,.3,1);max-width:300px;line-height:1.5;pointer-events:auto;}
.toast.show{transform:translateX(0);}
.t-ok{border-left-color:var(--gr);}
.t-err{border-left-color:#ff5f57;}

/* ── SECTION LABEL ── */
.sec{font-family:var(--mono);font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;color:var(--or);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec::after{content:'';flex:1;height:1px;background:var(--bdr);}

/* ── PAGE HEADER ── */
.ph{text-align:center;margin-bottom:24px;}
.ph-pill{display:inline-block;background:var(--odim);border:1px solid rgba(255,107,53,.3);color:var(--or);font-family:var(--mono);font-size:.54rem;letter-spacing:.2em;padding:3px 11px;border-radius:20px;margin-bottom:8px;}
.ph h1{font-family:var(--mono);font-size:.8rem;letter-spacing:.15em;color:var(--or);text-transform:uppercase;margin-bottom:4px;}
.ph p{font-size:.74rem;color:var(--dim);font-family:var(--mono);}

/* ── PREVIEW WINDOWS GRID ── */
.wgrid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.fw{grid-column:1/-1;}
@media(max-width:660px){.wgrid{grid-template-columns:1fr;}.fw{grid-column:1;}}

/* ── WINDOW ── */
.win{background:var(--surf);border:1px solid var(--bdr);border-radius:8px;overflow:hidden;box-shadow:0 6px 28px rgba(0,0,0,.55);}
.tbar{background:var(--surf2);border-bottom:1px solid var(--bdr);height:32px;display:flex;align-items:center;padding:0 10px;position:relative;}
.tbtns{display:flex;gap:5px;z-index:1;}
.tbtn{width:11px;height:11px;border-radius:50%;border:none;cursor:default;flex-shrink:0;}
.tb-cl{background:#ff5f57;}.tb-mn{background:#ffbd2e;}.tb-mx{background:#28c840;}
.ttl{font-family:var(--mono);font-size:.59rem;color:var(--dim);position:absolute;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;}
.wb{padding:13px 14px 12px;}

/* dialog */
.dtop{display:flex;align-items:flex-start;gap:11px;margin-bottom:11px;}
.dpri{font-size:12px;font-weight:600;color:var(--tx);margin-bottom:3px;}
.dsec{font-size:11px;color:var(--dim);line-height:1.6;font-family:var(--mono);}

/* list rows */
.lbox{background:var(--bg);border:1px solid var(--bdr);border-radius:4px;overflow:hidden;margin-bottom:10px;}
.lrow{display:flex;align-items:center;gap:9px;padding:7px 9px;border-bottom:1px solid var(--bdr);font-size:11px;color:var(--tx);cursor:pointer;transition:background .1s;user-select:none;}
.lrow:last-child{border-bottom:none;}
.lrow:hover{background:rgba(255,255,255,.03);}
.lrow.on{background:var(--odim);}
.rdo{width:13px;height:13px;border-radius:50%;border:2px solid var(--bdr2);flex-shrink:0;background:var(--surf2);display:flex;align-items:center;justify-content:center;}
.lrow.on .rdo{border-color:var(--or);}
.lrow.on .rdo::after{content:'';width:5px;height:5px;border-radius:50%;background:var(--or);}

/* ── INTERACTIVE INPUTS inside preview ── */
.inp{
  width:100%;
  background:var(--bg);
  border:1px solid var(--bdr2);
  border-radius:4px;
  padding:7px 10px;
  font-family:var(--mono);
  font-size:11px;
  color:var(--tx);
  outline:none;
  margin-bottom:9px;
  transition:border-color .15s;
  display:block;
}
.inp:focus{border-color:var(--or);box-shadow:0 0 0 2px rgba(255,107,53,.12);}
.inp::placeholder{color:var(--muted);}
.flbl{font-family:var(--mono);font-size:.56rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;display:block;}
.svc-hint{font-family:var(--mono);font-size:10px;color:var(--or);min-height:16px;margin-bottom:6px;}

/* ── QUALITY GRID — CLICKABLE in preview ── */
.qpg{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--bdr);border:1px solid var(--bdr);border-radius:4px;overflow:hidden;margin-bottom:10px;}
.qpc{
  background:var(--bg);
  padding:9px 4px;
  text-align:center;
  cursor:pointer;
  transition:background .12s;
  user-select:none;
}
.qpc:hover{background:rgba(255,107,53,.07);}
.qpc.on{background:var(--odim);}
.qpn{font-family:var(--mono);font-size:1.1rem;color:var(--or);display:block;line-height:1.2;}
.qpname{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--tx);display:block;margin-top:2px;}
.qpdesc{font-family:var(--mono);font-size:8px;color:var(--muted);display:block;margin-top:2px;}

/* progress */
.phead{display:flex;justify-content:space-between;font-family:var(--mono);font-size:11px;color:var(--dim);margin-bottom:5px;}
.ppct{color:var(--or);font-weight:700;}
.ptr{height:4px;background:var(--bdr);border-radius:4px;overflow:hidden;margin-bottom:10px;}
.pfill{height:100%;background:linear-gradient(90deg,var(--or),var(--red));border-radius:4px;animation:pani 3s ease-in-out infinite alternate;}
@keyframes pani{from{width:18%;}to{width:82%};}
.logbox{background:var(--bg);border:1px solid var(--bdr);border-radius:4px;padding:8px 10px;font-family:var(--mono);font-size:10px;color:var(--dim);line-height:1.8;margin-bottom:9px;max-height:95px;overflow-y:auto;}
.tok{color:var(--gr);}.ttrk{color:var(--or);}.tinf{color:var(--muted);}
.blink-dot{width:5px;height:5px;border-radius:50%;background:var(--or);display:inline-block;animation:blink 1s step-end infinite;}
@keyframes blink{50%{opacity:0;}}

/* about */
.ahd{display:flex;align-items:center;gap:11px;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--bdr);}
.aname{font-family:var(--mono);font-size:1.05rem;font-weight:700;color:var(--tx);}
.aname span{color:var(--or);}
.aver{font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:2px;}
.ir{display:flex;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:11px;gap:12px;}
.ir:last-child{border-bottom:none;}
.ik{font-family:var(--mono);font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;min-width:76px;flex-shrink:0;padding-top:1px;}
.iv{color:var(--tx);}.iv.or{color:var(--or);}.iv.gr{color:var(--gr);}

/* preview btn bar */
.bbar{display:flex;justify-content:flex-end;gap:6px;padding-top:9px;border-top:1px solid var(--bdr);margin-top:6px;}
.pb{font-family:var(--mono);font-size:11px;padding:5px 14px;border-radius:4px;border:1px solid var(--bdr);cursor:pointer;transition:all .14s;}
.pb-c{background:var(--surf2);color:var(--dim);}
.pb-c:hover{background:var(--bdr);color:var(--tx);}
.pb-ok{background:var(--or);color:#fff;font-weight:700;border-color:var(--red);box-shadow:0 2px 10px rgba(255,107,53,.2);}
.pb-ok:hover{background:#ff7d4d;}

/* ── GENERATOR ── */
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:8px;padding:18px 20px;margin-bottom:14px;box-shadow:0 4px 18px rgba(0,0,0,.28);}
.rl{font-family:var(--mono);font-size:.58rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;display:block;}
.rtxt,.ri{width:100%;background:var(--bg);border:1px solid var(--bdr2);border-radius:4px;padding:8px 10px;font-family:var(--mono);font-size:12px;color:var(--tx);outline:none;transition:border-color .15s;margin-bottom:12px;}
.rtxt{resize:vertical;min-height:88px;line-height:1.7;}
.rtxt:focus,.ri:focus{border-color:var(--or);box-shadow:0 0 0 2px rgba(255,107,53,.1);}
.rtxt::placeholder,.ri::placeholder{color:var(--muted);}
.prow{display:flex;gap:8px;margin-bottom:12px;}
.prow .ri{margin-bottom:0;flex:1;}
.bbrowse{font-family:var(--mono);font-size:11px;padding:7px 13px;background:var(--surf2);border:1px solid var(--bdr2);border-radius:4px;color:var(--dim);cursor:pointer;white-space:nowrap;transition:all .15s;}
.bbrowse:hover{border-color:var(--or);color:var(--or);}
.ucnt{font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:-8px;margin-bottom:9px;}
.ucnt.has{color:var(--or);}
.sr{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px;}
.sp{font-family:var(--mono);font-size:.54rem;letter-spacing:.1em;padding:2px 9px;border-radius:20px;background:var(--odim);border:1px solid rgba(255,107,53,.3);color:var(--or);}
.em{font-family:var(--mono);font-size:11px;color:#ff5f57;margin-top:-8px;margin-bottom:9px;display:none;}
.em.vis{display:block;}

/* quality in generator */
.qgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;}
.qopt{display:block;cursor:pointer;}
.qopt input{display:none;}
.qcard{background:var(--bg);border:1px solid var(--bdr);border-radius:5px;padding:10px 6px;text-align:center;transition:all .14s;user-select:none;}
.qcard:hover{border-color:var(--bdr2);}
.qopt input:checked+.qcard{border-color:var(--or);background:var(--odim);box-shadow:0 0 10px rgba(255,107,53,.13);}
.qn{font-family:var(--mono);font-size:1.25rem;color:var(--or);display:block;line-height:1.2;}
.qnm{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--tx);display:block;margin-top:3px;}
.qd{font-family:var(--mono);font-size:9px;color:var(--muted);display:block;margin-top:2px;}
@media(max-width:480px){.qgrid{grid-template-columns:repeat(3,1fr);}}

/* toggles */
.trow{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--bdr);cursor:pointer;}
.trow:last-child{border-bottom:none;}
.ttl2{font-size:13px;color:var(--tx);margin-bottom:2px;}
.tsub{font-family:var(--mono);font-size:10px;color:var(--muted);}
.sw{position:relative;width:38px;height:20px;flex-shrink:0;}
.sw input{opacity:0;width:0;height:0;}
.sl{position:absolute;inset:0;background:var(--surf2);border:1px solid var(--bdr2);border-radius:20px;transition:all .2s;cursor:pointer;}
.sl::before{content:'';position:absolute;height:14px;width:14px;left:2px;top:2px;background:var(--muted);border-radius:50%;transition:all .2s;}
input:checked+.sl{background:var(--odim);border-color:var(--or);}
input:checked+.sl::before{transform:translateX(18px);background:var(--or);}

/* generate btn */
.bgen{width:100%;padding:13px;font-family:var(--mono);font-size:.76rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;background:linear-gradient(135deg,var(--or),var(--red));color:#fff;border:none;border-radius:6px;cursor:pointer;box-shadow:0 4px 18px rgba(255,107,53,.28);transition:all .18s;margin-bottom:20px;}
.bgen:hover{transform:translateY(-1px);box-shadow:0 6px 26px rgba(255,107,53,.38);}
.bgen:active{transform:translateY(0);}

/* output */
.out{display:none;}.out.vis{display:block;}
.igrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
@media(max-width:460px){.igrid{grid-template-columns:1fr 1fr;}}
.ic{background:var(--surf);border:1px solid var(--bdr);border-radius:6px;padding:12px 14px;}
.icl{font-family:var(--mono);font-size:.54rem;color:var(--muted);text-transform:uppercase;letter-spacing:.15em;margin-bottom:5px;}
.icv{font-family:var(--mono);font-size:.95rem;color:var(--tx);font-weight:700;}
.icv.or{color:var(--or);}

.thd{display:flex;align-items:center;gap:8px;background:var(--surf2);border:1px solid var(--bdr);border-bottom:none;border-radius:6px 6px 0 0;padding:7px 12px;}
.dots{display:flex;gap:5px;}
.dot{width:10px;height:10px;border-radius:50%;}
.dr{background:#ff5f57;}.dy{background:#ffbd2e;}.dg{background:#28c840;}
.thl{font-family:var(--mono);font-size:.56rem;color:var(--muted);letter-spacing:.12em;flex:1;}
.bcopy{font-family:var(--mono);font-size:.56rem;letter-spacing:.1em;padding:3px 10px;background:var(--odim);border:1px solid rgba(255,107,53,.3);border-radius:3px;color:var(--or);cursor:pointer;transition:all .15s;}
.bcopy:hover{background:var(--or);color:#fff;}
.bcopy.done{background:var(--gr);border-color:var(--gr);color:#fff;}
.tbody{background:var(--bg);border:1px solid var(--bdr);border-radius:0 0 6px 6px;padding:12px 14px;font-family:var(--mono);font-size:11px;line-height:1.8;color:var(--dim);white-space:pre-wrap;max-height:290px;overflow-y:auto;margin-bottom:14px;}
.tbody::-webkit-scrollbar{width:3px;}
.tbody::-webkit-scrollbar-thumb{background:var(--bdr2);border-radius:2px;}
.cc{color:var(--muted);}
.cm{color:#87ceeb;font-weight:600;}
.cv{color:#98d982;}
.cf{color:#ffa07a;}
.cur{display:inline-block;width:7px;height:13px;background:var(--or);animation:blink 1s step-end infinite;vertical-align:middle;margin-left:2px;}

.foot{text-align:center;font-family:var(--mono);font-size:.57rem;color:var(--muted);letter-spacing:.1em;padding-top:20px;}
</style>
</head>
<body>

<!-- background grid (pointer-events:none set in CSS via .bg-grid) -->
<div class="bg-grid"></div>

<!-- Toast -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- Topbar -->
<div class="topbar">
  <div class="logo">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="26" height="26"><defs><linearGradient id="l0" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FF6B35"/><stop offset="100%" stop-color="#C0392B"/></linearGradient><linearGradient id="w0" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="white" stop-opacity=".95"/><stop offset="100%" stop-color="#FFE0D0" stop-opacity=".75"/></linearGradient></defs><rect x="2" y="2" width="60" height="60" rx="14" fill="url(#l0)"/><ellipse cx="21" cy="46" rx="8" ry="5.5" fill="url(#w0)"/><rect x="28.5" y="17" width="3.5" height="29" rx="1.5" fill="url(#w0)"/><path d="M32 17 Q50 21 48 33 Q44 27 32 25 Z" fill="url(#w0)"/><circle cx="46" cy="46" r="12" fill="rgba(0,0,0,.18)"/><line x1="46" y1="38" x2="46" y2="48" stroke="white" stroke-width="2.5" stroke-linecap="round"/><polyline points="41,45 46,51 51,45" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><line x1="40" y1="54" x2="52" y2="54" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
    Q<span>rip</span>
  </div>
  <div class="pills">
    <span class="pill">Qobuz</span><span class="pill">Deezer</span><span class="pill">Tidal</span><span class="pill">SoundCloud</span>
  </div>
  <div class="nav">
    <button class="nbtn on" onclick="goTab('preview',this)">App Preview</button>
    <button class="nbtn" onclick="goTab('generator',this)">Command Generator</button>
  </div>
</div>

<!-- ══════════════════ TAB: PREVIEW ══════════════════ -->
<div class="tab on" id="tab-preview">
<div class="page">

  <div class="ph">
    <div class="ph-pill">PREVIEW</div>
    <h1>Qrip v2.0.0 — Application Windows</h1>
    <p>© 2025 TheZupZup — All windows you will see on Linux Mint</p>
  </div>

  <div class="wgrid">

    <!-- 01 Main menu -->
    <div class="win">
      <div class="tbar"><div class="tbtns"><div class="tbtn tb-cl"></div><div class="tbtn tb-mn"></div><div class="tbtn tb-mx"></div></div><div class="ttl">Qrip v2.0.0</div></div>
      <div class="wb">
