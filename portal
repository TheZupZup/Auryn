<script>
// ─────────────────────────────────────────
//  TABS
// ─────────────────────────────────────────
function goTab(name, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.nbtn').forEach(b => b.classList.remove('on'));
  document.getElementById('tab-' + name).classList.add('on');
  btn.classList.add('on');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ─────────────────────────────────────────
//  TOAST
// ─────────────────────────────────────────
function toast(msg, type) {
  const c = document.getElementById('toastWrap');
  const t = document.createElement('div');
  t.className = 'toast t-' + (type || 'info');
  t.textContent = msg;
  c.appendChild(t);
  requestAnimationFrame(() => requestAnimationFrame(() => t.classList.add('show')));
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 320); }, 3200);
}

// ─────────────────────────────────────────
//  PROGRESS ANIMATION
// ─────────────────────────────────────────
const ppct = document.getElementById('ppct');
let pv = 18, pd = 1;
setInterval(() => { pv += pd * 0.4; if (pv >= 82) pd = -1; if (pv <= 18) pd = 1; ppct.textContent = Math.round(pv) + '%'; }, 50);

// ─────────────────────────────────────────
//  PREVIEW: main menu selection
// ─────────────────────────────────────────
let menuSel = 0;
function selectMenu(n) {
  menuSel = n;
  document.querySelectorAll('#mainMenu .lrow').forEach((r, i) => r.classList.toggle('on', i === n));
}
function mainMenuOK() {
  const actions = ['generator', 'generator', null, null];
  if (menuSel === 0 || menuSel === 1) {
    goTab('generator', document.querySelectorAll('.nbtn')[1]);
  } else if (menuSel === 3) {
    document.querySelector('.win:last-child').scrollIntoView({ behavior: 'smooth' });
    toast('ℹ️ See the About window below!', 'info');
  } else {
    toast('📋 Logs are only available in the installed app on Linux Mint.', 'info');
  }
}

// ─────────────────────────────────────────
//  PREVIEW: quality selection
// ─────────────────────────────────────────
let pvQ = 3;
const qLabels = { 0:'MP3 128kbps', 1:'MP3 320kbps', 2:'CD FLAC (2)', 3:'Hi-Res FLAC (3)', 4:'MQA/Max (4)' };

function pvSelectQ(n, el) {
  pvQ = n;
  document.querySelectorAll('.qpg .qpc').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('pvQlbl').textContent = qLabels[n];
  toast('✓ Quality set: ' + qLabels[n], 'ok');
}

// ─────────────────────────────────────────
//  PREVIEW: URL detect
// ─────────────────────────────────────────
function pvDetect(v) {
  const el = document.getElementById('pvSvc');
  if (!v.trim()) { el.textContent = ''; return; }
  const s = detectSvc(v.trim());
  el.textContent = '✓ ' + s + ' detected';
}

// ─────────────────────────────────────────
//  PREVIEW: send to generator
// ─────────────────────────────────────────
function pvSendToGen() {
  const url  = document.getElementById('pvUrl').value.trim();
  const dest = document.getElementById('pvDest').value.trim();
  if (url)  document.getElementById('genUrl').value  = url;
  if (dest) document.getElementById('genDest').value = dest;
  const r = document.querySelector(`input[name="gq"][value="${pvQ}"]`);
  if (r) r.checked = true;
  goTab('generator', document.querySelectorAll('.nbtn')[1]);
  if (url) document.getElementById('genUrl').dispatchEvent(new Event('input'));
  toast('✓ Settings transferred — ready to generate!', 'ok');
}

// ─────────────────────────────────────────
//  GENERATOR: URL detection
// ─────────────────────────────────────────
document.getElementById('genUrl').addEventListener('input', function() {
  const urls = parseURLs(this.value);
  const cnt  = document.getElementById('ucnt');
  const sr   = document.getElementById('srRow');
  if (urls.length === 0) {
    cnt.textContent = '— no URL detected';
    cnt.className = 'ucnt';
    sr.innerHTML = '';
  } else {
    cnt.textContent = `✓ ${urls.length} URL${urls.length > 1 ? 's' : ''} detected`;
    cnt.className = 'ucnt has';
    const svcs = [...new Set(urls.map(detectSvc))];
    sr.innerHTML = svcs.map(s => `<span class="sp">${s}</span>`).join('');
  }
});

function parseURLs(raw) {
  return raw.split(/[\n,; ]+/).map(u => u.trim()).filter(u => u.startsWith('http'));
}

function detectSvc(url) {
  if (url.includes('qobuz'))      return 'Qobuz';
  if (url.includes('deezer'))     return 'Deezer';
  if (url.includes('tidal'))      return 'Tidal';
  if (url.includes('soundcloud')) return 'SoundCloud';
  return 'Unknown service';
}

// ─────────────────────────────────────────
//  GENERATE COMMANDS
// ─────────────────────────────────────────
let _plain = '';

function generate() {
  const raw   = document.getElementById('genUrl').value;
  const dest  = document.getElementById('genDest').value.trim() || '~/Music/Downloads';
  const q     = document.querySelector('input[name="gq"]:checked').value;
  const force = document.getElementById('oForce').checked;
  const urls  = parseURLs(raw);
  const err   = document.getElementById('urlErr');

  if (urls.length === 0) { err.classList.add('vis'); return; }
  err.classList.remove('vis');

  const qmap = { '0':'MP3 128kbps','1':'MP3 320kbps','2':'CD FLAC','3':'Hi-Res FLAC','4':'MQA/Max' };
  const e = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  // Info cards
  document.getElementById('infoGrid').innerHTML =
    `<div class="ic"><div class="icl">URLs</div><div class="icv or">${urls.length}</div></div>` +
    `<div class="ic"><div class="icl">Quality</div><div class="icv or">${qmap[q]}</div></div>` +
    `<div class="ic"><div class="icl">Destination</div><div class="icv" style="font-size:10px;word-break:break-all;">${dest}</div></div>`;

  // Terminal lines
  const H  = '${HOME}', RI = '${RUN_ID}', RD = '${RUN_DIR}';
  const ln = [];
  ln.push(`<span class="cc"># Qrip v2.0.0 — ${new Date().toLocaleString('en-US')}</span>`);
  ln.push(`<span class="cc"># Quality: ${qmap[q]} | Destination: ${dest}</span>`);
  ln.push('');
  ln.push(`<span class="cc"># 1. Prepare isolated config</span>`);
  ln.push(`<span class="cm">RUN_ID</span>=<span class="cv">"$(date +'%Y-%m-%d_%H-%M-%S')"</span>`);
  ln.push(`<span class="cm">RUN_DIR</span>=<span class="cv">"${e(H)}/.local/state/qrip/run/${e(RI)}"</span>`);
  ln.push(`<span class="cm">mkdir</span> -p <span class="cv">"${e(RD)}/config/streamrip"</span>`);
  ln.push(`<span class="cm">cp</span> <span class="cv">"~/.config/streamrip/config.toml"</span> <span class="cv">"${e(RD)}/config/streamrip/config.toml"</span>`);
  ln.push('');
  ln.push(`<span class="cc"># 2. Patch destination</span>`);
  ln.push(`<span class="cm">sed</span> -i <span class="cf">'0,/folder\\s*=\\s*".*"/s||folder = "${dest.replace(/[/&]/g,'\\$&')}"|'</span> <span class="cv">"${e(RD)}/config/streamrip/config.toml"</span>`);
  ln.push('');
  ln.push(`<span class="cc"># 3. Patch quality (${q})</span>`);
  ln.push(`<span class="cm">sed</span> -i <span class="cf">'s/^quality\\s*=\\s*[0-9]*/quality = ${q}/'</span> <span class="cv">"${e(RD)}/config/streamrip/config.toml"</span>`);
  ln.push('');
  if (force) {
    ln.push(`<span class="cc"># 4. Delete DB (force re-download)</span>`);
    ln.push(`<span class="cm">rm</span> -f <span class="cv">"${e(RD)}/config/streamrip/downloads.db"</span>`);
    ln.push('');
  }
  ln.push(`<span class="cc"># ${force?'5':'4'}. Set config path</span>`);
  ln.push(`<span class="cm">export</span> <span class="cf">XDG_CONFIG_HOME</span>=<span class="cv">"${e(RD)}/config"</span>`);
  ln.push('');
  ln.push(`<span class="cc"># ${force?'6':'5'}. Start downloads</span>`);
  urls.forEach((url, i) => {
    ln.push(`<span class="cc">#   URL ${i+1}/${urls.length} — ${detectSvc(url)}</span>`);
    ln.push(`<span class="cm">rip</span> url <span class="cv">"${e(url)}"</span>`);
    if (i < urls.length - 1) ln.push('');
  });
  ln.push('');
  ln.push(`<span class="cc"># Done — files in: ${dest}</span>`);
  ln.push(`<span class="cur"></span>`);

  document.getElementById('t1').innerHTML = ln.join('\n');

  // Plain script
  const ul = urls.map((u,i) => `  # URL ${i+1}/${urls.length} — ${detectSvc(u)}\n  rip url "${u}"`).join('\n\n');
  const d  = dest.replace(/[/&]/g,'\\$&');
  _plain = `#!/usr/bin/env bash
# Qrip v2.0.0 — Generated ${new Date().toLocaleString('en-US')}
# Quality: ${qmap[q]} | Destination: ${dest} | URLs: ${urls.length}

set -euo pipefail

DEST="${dest}"
RUN_ID="$(date +'%Y-%m-%d_%H-%M-%S')"
RUN_DIR="\${HOME}/.local/state/qrip/run/\${RUN_ID}"
RUN_CFG="\${RUN_DIR}/config"
RUN_SR="\${RUN_CFG}/streamrip"

mkdir -p "\${RUN_SR}"
cp -f "\${HOME}/.config/streamrip/config.toml" "\${RUN_SR}/config.toml"
sed -i '0,/folder\\s*=\\s*".*"/s||folder = "${d}"|' "\${RUN_SR}/config.toml"
sed -i 's/^quality\\s*=\\s*[0-9]*/quality = ${q}/' "\${RUN_SR}/config.toml"
${force ? 'rm -f "${RUN_SR}/downloads.db"' : ''}
export XDG_CONFIG_HOME="\${RUN_CFG}"

${ul}

echo "✅ Done — files in: ${dest}"
`;
  const sh = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/(#[^\n]*)/g,'<span style="color:var(--muted)">$1</span>')
    .replace(/\b(set|export|mkdir|cp|sed|rm|echo|rip)\b/g,'<span style="color:#87ceeb;font-weight:600">$1</span>')
    .replace(/"([^"]*)"/g,'<span style="color:#98d982">"$1"</span>');

  const t2 = document.getElementById('t2');
  t2.innerHTML = sh(_plain);
  t2._plain = _plain;

  document.getElementById('outSec').classList.add('vis');
  setTimeout(() => document.getElementById('outSec').scrollIntoView({ behavior:'smooth', block:'start' }), 80);
  toast(`✓ Commands generated for ${urls.length} URL${urls.length>1?'s':''}!`, 'ok');
}

// ─────────────────────────────────────────
//  COPY
// ─────────────────────────────────────────
function doCopy(btnId, termId) {
  const el  = document.getElementById(termId);
  const txt = el._plain || el.innerText.replace(/[\u25AE\u2588]/g, '');
  if (!txt || txt.trim() === 'Generate commands first.') {
    toast('⚠ Generate commands first!', 'err'); return;
  }
  navigator.clipboard.writeText(txt).then(() => {
    const btn = document.getElementById(btnId);
    const orig = btn.textContent;
    btn.textContent = '✓ Copied!';
    btn.classList.add('done');
    setTimeout(() => { btn.textContent = orig; btn.classList.remove('done'); }, 2000);
    toast('✓ Copied to clipboard!', 'ok');
  }).catch(() => toast('⚠ Copy failed — select the text manually.', 'err'));
}
</script>
